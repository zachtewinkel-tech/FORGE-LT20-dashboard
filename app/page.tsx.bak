"use client";

import React, { useEffect, useMemo, useState } from "react";

type Tab =
  | "dailyBrief"
  | "actionItems"
  | "positions"
  | "tradeLog"
  | "performance"
  | "fundProfile"
  | "ruleSet"
  | "settings";

type TradeType =
  | "deposit"
  | "withdrawal"
  | "buy_spy"
  | "sell_spy"
  | "sell_xsp_call"
  | "buy_xsp_call";

type Regime = "R0" | "R1" | "R2" | "R3";

interface TradeBase {
  id: string;
  createdAt: string;
  date: string;
  notes: string;
}

interface DepositTrade extends TradeBase {
  type: "deposit";
  amount: number;
}

interface WithdrawalTrade extends TradeBase {
  type: "withdrawal";
  amount: number;
}

interface BuySpyTrade extends TradeBase {
  type: "buy_spy";
  shares: number;
  price: number;
}

interface SellSpyTrade extends TradeBase {
  type: "sell_spy";
  shares: number;
  price: number;
}

interface SellXspCallTrade extends TradeBase {
  type: "sell_xsp_call";
  expiry: string;
  strike: number;
  contracts: number;
  price: number;
}

interface BuyXspCallTrade extends TradeBase {
  type: "buy_xsp_call";
  expiry: string;
  strike: number;
  contracts: number;
  price: number;
}

type Trade =
  | DepositTrade
  | WithdrawalTrade
  | BuySpyTrade
  | SellSpyTrade
  | SellXspCallTrade
  | BuyXspCallTrade;

interface AppSettings {
  finnhubApiKey: string;
  whitepaperUrl: string;
  spyPrice: number;
  xspPrice: number;
  vix: number;
  ma50: number;
  ma200: number;
  trendSuppressionScore: number;
  marginRate: number;
  optionMarks: Record<string, number>;
}

interface TradeFormState {
  date: string;
  type: TradeType;
  amount: string;
  shares: string;
  price: string;
  contracts: string;
  expiry: string;
  strike: string;
  notes: string;
}

interface OpenShortCallPosition {
  key: string;
  expiry: string;
  strike: number;
  quantity: number;
  avgOpenPremium: number;
  currentMark: number;
  marketValue: number;
  unrealizedPnl: number;
}

interface LedgerSnapshot {
  cash: number;
  marginDebt: number;
  spyShares: number;
  spyAvgCost: number;
  spyMarketValue: number;
  spyRealizedPnl: number;
  spyUnrealizedPnl: number;
  shortCalls: OpenShortCallPosition[];
  optionMarketValue: number;
  optionRealizedPnl: number;
  optionUnrealizedPnl: number;
  deposits: number;
  withdrawals: number;
  netContributions: number;
  netLiquidationValue: number;
  totalRealizedPnl: number;
  totalUnrealizedPnl: number;
  totalPnl: number;
}

